# Configuración de la base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=systemsware
DB_USER=postgres
DB_PASSWORD=1234

# Configuración del servidor
PORT=3000
NODE_ENV=development

# Secret para JWT (cambiar en producción) - Mínimo 32 caracteres
JWT_SECRET=systemsware_super_secret_key_change_this_in_production

# Secret para Refresh Tokens - DEBE ser diferente a JWT_SECRET y mínimo 32 caracteres
REFRESH_SECRET=systemsware_refresh_secret_different_key_32chars
